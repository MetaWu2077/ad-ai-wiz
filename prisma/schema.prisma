// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Campaign {
  id             String   @id @default(cuid())
  shop           String
  productId      String
  productTitle   String
  productImage   String?
  productUrl     String?
  targetAudience String?
  sellingPoints  String
  dailyBudget    Float    @default(20)
  adStyle        String
  competitorRef  String?
  videoUrl       String?
  thumbnailUrl   String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  shop       String
  campaignId String
  type       String
  title      String
  body       String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}
